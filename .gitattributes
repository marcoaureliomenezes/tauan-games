# aero-fighters-v2 — binary asset tracking via git-lfs.
# Scoped to aero-fighters-v2/** to avoid disturbing v1 (aero-fighters/, tauan-trex/) trees.

# 3D mesh source files
aero-fighters-v2/Content/**/*.glb filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.fbx filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.obj filter=lfs diff=lfs merge=lfs -text

# UE5 binary assets (generated by editor; .uasset and .umap)
aero-fighters-v2/Content/**/*.uasset filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.umap   filter=lfs diff=lfs merge=lfs -text

# Audio
aero-fighters-v2/Content/**/*.wav filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.ogg filter=lfs diff=lfs merge=lfs -text

# Textures (we forbid external imports per CV-08, but engine-generated PNGs/TGAs may land)
aero-fighters-v2/Content/**/*.png filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.tga filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Content/**/*.exr filter=lfs diff=lfs merge=lfs -text

# Test baselines (per-platform screenshot-diff references) — AC-V2-18
aero-fighters-v2/Tests/Baselines/**/*.png filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Tests/Baselines/**/*.jpg filter=lfs diff=lfs merge=lfs -text

# Perf profiling artifacts (UE5 Insights traces) — AC-V2-19
aero-fighters-v2/Reports/**/*.utrace filter=lfs diff=lfs merge=lfs -text

# Closure demo capture — AC-V2-MVP-SUMMARY (Wave 7)
aero-fighters-v2/Reports/closure/*.mp4 filter=lfs diff=lfs merge=lfs -text
aero-fighters-v2/Reports/closure/*.webm filter=lfs diff=lfs merge=lfs -text

# Note: anything under Saved/, Binaries/, Intermediate/, DerivedDataCache/ is
# ignored entirely by .gitignore — LFS rules above intentionally do not cover those.
