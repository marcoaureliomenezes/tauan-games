# aero-fighters-v2 — local environment TEMPLATE
#
# This file is a TEMPLATE. Copy it to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
#
# See SPEC §8 (Secret & Key Management) for the canonical storage model:
#   Canonical path: aero-fighters-v2/.env.local (gitignored, operator-owned)
#   Optional upgrade: materialize from 1Password via wrapper script (deferred).
#
# Release: aero-fighters-v2-godot-stylized-inhauma-v1

# ---------------------------------------------------------------------------
# GODOT — binary path
# ---------------------------------------------------------------------------
# Path to the Godot 4 stable Mono binary on this machine.
# Default after unzipping to ~/godot/:
#   $HOME/godot/Godot_v4.x-stable_mono_linux_x86_64/Godot_v4.x-stable_mono_linux.x86_64
# Recorded per operator setup in aero-fighters-v2/docs/godot-version.md.
GODOT_BIN_PATH=/path/to/godot
# GODOT_BIN_PATH=$HOME/godot/godot

# ---------------------------------------------------------------------------
# NASA EarthData credentials (SRTM heightmap download — FR-V2-G-01)
# ---------------------------------------------------------------------------
# Free account at urs.earthdata.nasa.gov. No billing, read-only public dataset.
# Required by Tools/inhauma-data-fetch.py to download SRTM 30m tiles.
# Rotation cadence: annual or on suspected leak (low-risk: read-only public data).
# Already in place per operator setup 2026-05-17 (TASKS.md physical state note).
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# ---------------------------------------------------------------------------
# OSM bounding box — Inhaúma MG, 20 km radius (FR-V2-G-01)
# ---------------------------------------------------------------------------
# WGS84 decimal degrees. Default: ±0.20° around (-19.47, -44.46).
# Required by Tools/inhauma-data-fetch.py for the OSM clip step.
# Change only if you need a different world extent — keep consistent with
# GameConfig.tres (resources/GameConfig.tres, world_origin field).
OSM_BBOX_MIN_LAT=-19.67
OSM_BBOX_MAX_LAT=-19.27
OSM_BBOX_MIN_LON=-44.66
OSM_BBOX_MAX_LON=-44.26
