[gd_scene load_steps=10 format=3 uid="uid://main_scene"]

[ext_resource type="PackedScene" uid="uid://cel_shader_pass" path="res://scenes/CelShaderPass.tscn" id="1_cel_pass"]
[ext_resource type="PackedScene" uid="uid://player_scene" path="res://scenes/Player.tscn" id="2_player"]
[ext_resource type="PackedScene" uid="uid://hud_scene" path="res://scenes/HUD.tscn" id="3_hud"]
[ext_resource type="PackedScene" uid="uid://inhauma_buildings" path="res://scenes/InhaumaBuildings.tscn" id="4_buildings"]
[ext_resource type="PackedScene" uid="uid://inhauma_foliage" path="res://scenes/InhaumaFoliage.tscn" id="5_foliage"]
[ext_resource type="Script" path="res://scripts/target_spawner.gd" id="6_target_spawner"]
[ext_resource type="PackedScene" uid="uid://factory_scene" path="res://scenes/Targets/Factory.tscn" id="7_factory"]
[ext_resource type="PackedScene" uid="uid://base_scene" path="res://scenes/Targets/Base.tscn" id="8_base"]
[ext_resource type="PackedScene" uid="uid://aa_cluster_scene" path="res://scenes/Targets/AAGunCluster.tscn" id="9_aa_cluster"]

[node name="Main" type="Node3D"]

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]

[node name="Sun" type="DirectionalLight3D" parent="."]
rotation_degrees = Vector3(-45.0, 45.0, 0.0)
light_energy = 1.3
shadow_enabled = true

; Camera3D fallback — inactive; Player's chase camera takes current=true on _ready
[node name="Camera3D" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 0.866, 0.5, 0, -0.5, 0.866, 0, 80, 200)
current = false

; Player aircraft — RigidBody3D with flight_arcade.gd + camera_controller.gd.
; Spawns at 2095 m above world origin per AC-V2-G-03 (player_controller._ready).
[node name="Player" parent="." instance=ExtResource("2_player")]

; HUD CanvasLayer — 8 elements per FR-V2-G-10; hud.gd polls Player each _process.
[node name="HUD" parent="." instance=ExtResource("3_hud")]

; CelShaderPass: fullscreen CanvasLayer (T-G-10 lane — do not touch)
[node name="CelShaderPass" parent="." instance=ExtResource("1_cel_pass")]

; Buildings: OSM building extrusion via MultiMeshInstance3D (T-G-17)
[node name="Buildings" parent="." instance=ExtResource("4_buildings")]

; Foliage: OSM landuse scatter via MultiMeshInstance3D (T-G-18)
[node name="Foliage" parent="." instance=ExtResource("5_foliage")]

; Targets container — T-G-20 adds factory/base/aa_cluster instances under this node.
; TargetSpawner registers children with MissionManager on _ready + handles cycle respawn.
[node name="Targets" type="Node3D" parent="."]

; --- Factory (T-G-20) — placeholder position, real WGS84 wired by MissionManager later ---
[node name="Factory" parent="Targets" instance=ExtResource("7_factory")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 50, 0, 100)

; --- Base (T-G-20) — placeholder position ---
[node name="Base" parent="Targets" instance=ExtResource("8_base")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -100, 0, 50)

; --- AA Gun Cluster (T-G-20) — placeholder position ---
[node name="AAGunCluster" parent="Targets" instance=ExtResource("9_aa_cluster")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 200)

; TargetSpawner — finds Targets children, registers with MissionManager (T-G-19).
[node name="TargetSpawner" type="Node" parent="."]
script = ExtResource("6_target_spawner")

; --- Wave 2 / future children ---
; Terrain3D node — operator finishes import in editor (T-G-16, Wave 2 DONE)
