[gd_scene load_steps=2 format=3 uid="uid://hud_scene"]

[ext_resource type="Script" path="res://scripts/hud.gd" id="1_hud"]

; HUD — 8 Control elements per FR-V2-G-10.
; hud.gd polls Player flight state each _process tick and subscribes to MissionManager signals.

[node name="HUD" type="CanvasLayer"]
layer = 10
script = ExtResource("1_hud")

[node name="Control" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

; 1. Airspeed (m/s) — bottom-left
[node name="Airspeed" type="Label" parent="Control"]
layout_mode = 0
offset_left = 20.0
offset_top = 520.0
offset_right = 240.0
offset_bottom = 548.0
text = "SPD: 0 m/s"
modulate = Color(0.9, 1.0, 0.9, 1)

; 2. Altitude AGL — bottom-left
[node name="AltitudeAGL" type="Label" parent="Control"]
layout_mode = 0
offset_left = 20.0
offset_top = 555.0
offset_right = 260.0
offset_bottom = 583.0
text = "ALT: 0 m"
modulate = Color(0.9, 1.0, 0.9, 1)

; 3. Throttle % — bottom-left
[node name="Throttle" type="Label" parent="Control"]
layout_mode = 0
offset_left = 20.0
offset_top = 590.0
offset_right = 220.0
offset_bottom = 618.0
text = "THR: 50%"
modulate = Color(1.0, 1.0, 0.7, 1)

; 4. Cannon ammo — bottom-left
[node name="Ammo" type="Label" parent="Control"]
layout_mode = 0
offset_left = 20.0
offset_top = 625.0
offset_right = 220.0
offset_bottom = 653.0
text = "AMMO: INF"
modulate = Color(1.0, 0.8, 0.5, 1)

; 5. Crosshair — center screen (cel-friendly vector-style "+" via Label)
[node name="Crosshair" type="Label" parent="Control"]
layout_mode = 3
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -16.0
offset_top = -16.0
offset_right = 16.0
offset_bottom = 16.0
text = "+"
horizontal_alignment = 1
vertical_alignment = 1
modulate = Color(1, 1, 1, 0.8)

; 6. Score — top-right
[node name="Score" type="Label" parent="Control"]
layout_mode = 0
offset_left = 1680.0
offset_top = 20.0
offset_right = 1900.0
offset_bottom = 48.0
text = "SCORE: 0"
horizontal_alignment = 2
modulate = Color(1.0, 0.9, 0.5, 1)

; 7. Mission progress: MissionN counter + target icons (alive/destroyed glyphs)
[node name="MissionProgress" type="Control" parent="Control"]
layout_mode = 0
offset_left = 1680.0
offset_top = 55.0
offset_right = 1900.0
offset_bottom = 140.0

[node name="MissionN" type="Label" parent="Control/MissionProgress"]
layout_mode = 0
offset_left = 0.0
offset_top = 0.0
offset_right = 220.0
offset_bottom = 28.0
text = "Mission 1"
horizontal_alignment = 2
modulate = Color(0.9, 0.9, 1.0, 1)

[node name="TargetIcons" type="Label" parent="Control/MissionProgress"]
layout_mode = 0
offset_left = 0.0
offset_top = 34.0
offset_right = 220.0
offset_bottom = 62.0
text = "[F] [B] [AA]"
horizontal_alignment = 2
modulate = Color(0.9, 0.9, 1.0, 1)

; 8. Boundary warning — top-center, hidden until player is > 18 km from origin (FR-V2-G-19)
[node name="BoundaryWarning" type="Label" parent="Control"]
layout_mode = 3
anchors_preset = 5
anchor_left = 0.5
anchor_top = 0.0
anchor_right = 0.5
anchor_bottom = 0.0
offset_left = -180.0
offset_top = 20.0
offset_right = 180.0
offset_bottom = 48.0
text = "RESTRICTED ZONE"
modulate = Color(1, 0.1, 0.1, 1)
visible = false
horizontal_alignment = 1
