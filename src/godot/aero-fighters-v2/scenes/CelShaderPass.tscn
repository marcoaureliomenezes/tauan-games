; CelShaderPass.tscn
; Screen-space cel-shader pass for Aero Fighters v2 (T-G-10, FR-V2-G-11).
;
; Architecture note:
;   Godot 4 canvas_item shaders cannot access hint_depth_texture or
;   hint_normal_roughness_texture (Forward+ only in spatial shaders).
;   We therefore use a spatial shader on a QuadMesh that covers the full
;   viewport.  The attached GDScript (cel_shader_pass.gd) reparents the
;   quad to the active Camera3D at _ready so it always sits at z=-near-0.01
;   in camera space, rendering over all 3D content.
;
;   The CanvasLayer wrapper (layer=10) is kept as the PackedScene root so
;   Main.tscn can safely instance this scene anywhere in the tree;
;   the GDScript moves the actual quad to camera space at runtime.

[gd_scene load_steps=5 format=3 uid="uid://cel_shader_pass"]

[ext_resource type="Script"  path="res://scripts/cel_shader_pass.gd" id="1_script"]
[ext_resource type="Shader"  path="res://shaders/cel_screen_space.gdshader" id="2_shader"]

[sub_resource type="ShaderMaterial" id="3_cel_mat"]
shader = ExtResource("2_shader")
shader_parameter/bands              = 3.0
shader_parameter/depth_edge_thresh  = 0.04
shader_parameter/normal_edge_thresh = 0.55
shader_parameter/saturation_lift    = 1.15
shader_parameter/outline_color      = Color(0.05, 0.05, 0.05, 1.0)

[sub_resource type="QuadMesh" id="4_quad"]
size = Vector2(2.0, 2.0)

[node name="CelShaderPass" type="Node3D"]
script = ExtResource("1_script")

[node name="CelPass" type="MeshInstance3D" parent="."]
mesh = SubResource("4_quad")
material_override = SubResource("3_cel_mat")
cast_shadow = 0
extra_cull_margin = 16384.0
