[gd_resource type="StandardMaterial3D" format=3 uid="uid://m_cel_metallic"]

; M_CelMetallic — cel-friendly metallic variant for radar dishes and AA gun
; barrels. Slightly cooler grey + small metallic kick gives a different toon
; band after quantization, distinguishing metal subassemblies from concrete /
; industrial slab. Used by base.tscn (radar dish) and aa_cluster.tscn (barrels).
;
; Per FR-V2-G-11. No external textures — fully procedural.

[resource]
shading_mode = 2
albedo_color = Color(0.55, 0.55, 0.55, 1)
metallic = 0.4
roughness = 0.5
cull_mode = 0
