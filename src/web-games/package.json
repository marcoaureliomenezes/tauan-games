{
  "name": "tauan-games-tests",
  "private": true,
  "scripts": {
    "test": "playwright test --config=tests/playwright.config.js",
    "test:james-bond:unit": "node tests/james-bond/unit.mjs",
    "test:james-bond:e2e": "playwright test --config=tests/james-bond/playwright.config.js",
    "test:james-bond": "npm run test:james-bond:unit && npm run test:james-bond:e2e",
    "test:trex": "playwright test tests/trex/ --config=tests/playwright.config.js",
    "test:aero": "playwright test tests/aero-fighters/ --config=tests/playwright.config.js",
    "test:aero:e2e": "playwright test tests/aero-fighters/ --config=tests/playwright.config.js",
    "validate:aero-map": "node --experimental-default-type=module tests/aero-fighters/tools/validate-aero-map.js",
    "test:aero:unit": "node --experimental-default-type=module tests/aero-fighters/tools/test-aero-unit.js",
    "test:aero:sim": "node --experimental-default-type=module tests/aero-fighters/tools/test-aero-sim.js && node --experimental-default-type=module tests/aero-fighters/tools/test-aero-sortie-sim.js && node --experimental-default-type=module tests/aero-fighters/tools/test-aero-weapons-sim.js && node --experimental-default-type=module tests/aero-fighters/tools/test-aero-taxi-sim.js && node --experimental-default-type=module tests/aero-fighters/tools/test-aero-formations.mjs",
    "test:aero:formations": "node --experimental-default-type=module tests/aero-fighters/tools/test-aero-formations.mjs",
    "test:aero:qa": "npm run validate:aero-map && npm run test:aero:unit && npm run test:aero:sim && npm run test:aero:e2e",
    "test:space-war:unit": "node --experimental-default-type=module tests/space-war/tools/test-celestial-unit.js && node --experimental-default-type=module tests/space-war/tools/test-ballistics-unit.js && node --experimental-default-type=module tests/space-war/tools/test-physics-unit.js && node --experimental-default-type=module tests/space-war/tools/test-mode-unit.js",
    "test:space-war": "playwright test tests/space-war/ --config=tests/playwright.config.js",
    "test:far-west": "playwright test tests/far-west/ --config=tests/playwright.config.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
