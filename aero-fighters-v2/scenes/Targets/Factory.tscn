[gd_scene load_steps=8 format=3 uid="uid://factory_scene"]

; Factory target — HP 20, single-stage mega-explosion on kill.
; Geometry (own-work, hand-modeled in Godot primitives, T-G-20 Wave 4):
;   - MainBuilding   BoxMesh       20 × 8 × 15 m (industrial slab)
;   - SmokeStack1..3 CylinderMesh  h=12 m, r=1.5 m (spaced 4 m along +X)
;   - Annex          BoxMesh        5 × 4 × 4 m
; Collision: single BoxShape3D ~24 × 12 × 16 m covering the assembly.
; Material: M_CelTarget.tres on all primitives.
; Script: scripts/targets/factory.gd (extends TargetBase).
;
; Approx tri count (Godot primitive defaults):
;   BoxMesh ≈ 12 tris × 2  = 24
;   CylinderMesh (radial=16, rings=2) ≈ 96 × 3 = 288
;   Total ≈ 312 tris  — well within budget.

[ext_resource type="Material" uid="uid://m_cel_target" path="res://Content/Materials/M_CelTarget.tres" id="1_celmat"]
[ext_resource type="Script" path="res://scripts/targets/factory.gd" id="2_factory_gd"]

[sub_resource type="BoxMesh" id="BoxMesh_main"]
size = Vector3(20, 8, 15)

[sub_resource type="CylinderMesh" id="CylinderMesh_stack"]
top_radius = 1.5
bottom_radius = 1.5
height = 12.0
radial_segments = 16
rings = 2

[sub_resource type="BoxMesh" id="BoxMesh_annex"]
size = Vector3(5, 4, 4)

[sub_resource type="BoxShape3D" id="BoxShape3D_factory"]
size = Vector3(24, 14, 16)

[node name="Factory" type="StaticBody3D"]
script = ExtResource("2_factory_gd")

; --- Main building (centered, sits on +Y so base = ground plane) ---
[node name="MainBuilding" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 4, 0)
mesh = SubResource("BoxMesh_main")
surface_material_override/0 = ExtResource("1_celmat")

; --- 3 Smokestacks along +X edge of the main building, spaced 4 m apart ---
[node name="SmokeStack1" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4, 14, -6)
mesh = SubResource("CylinderMesh_stack")
surface_material_override/0 = ExtResource("1_celmat")

[node name="SmokeStack2" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 14, -6)
mesh = SubResource("CylinderMesh_stack")
surface_material_override/0 = ExtResource("1_celmat")

[node name="SmokeStack3" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 4, 14, -6)
mesh = SubResource("CylinderMesh_stack")
surface_material_override/0 = ExtResource("1_celmat")

; --- Annex (offset to +X side, attached to main building) ---
[node name="Annex" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 12.5, 2, 5)
mesh = SubResource("BoxMesh_annex")
surface_material_override/0 = ExtResource("1_celmat")

; --- Single bounding collision hull (covers main + stacks + annex) ---
[node name="CollisionShape3D" type="CollisionShape3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 7, 0)
shape = SubResource("BoxShape3D_factory")
