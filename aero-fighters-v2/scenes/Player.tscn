[gd_scene load_steps=4 format=3 uid="uid://player_scene"]

[ext_resource type="Script" path="res://scripts/player_controller.gd" id="1_player_ctrl"]
[ext_resource type="Script" path="res://scripts/flight_arcade.gd" id="2_flight"]
[ext_resource type="Script" path="res://scripts/camera_controller.gd" id="3_cam_ctrl"]
[ext_resource type="PackedScene" uid="uid://aircraft_scene" path="res://Content/Aircraft/aircraft.tscn" id="4_aircraft"]

; Player aircraft pawn.
; Root is RigidBody3D per OQ-V2-G-08 resolution — physics-driven arcade flight.
; Scripts: player_controller.gd (spawn + _integrate_forces), flight_arcade.gd (flight model),
; camera_controller.gd (chase + cockpit cameras).
;
; T-G-15 update (Wave 3, game-designer lane):
;   - Removed the Wave 1 placeholder MeshInstance3D + CollisionShape3D + 3 root-level
;     Marker3D sockets (MuzzleSocket / ChaseCamSocket / CockpitCamSocket).
;   - Replaced with an instance of Content/Aircraft/aircraft.tscn (named "Aircraft").
;   - The aircraft.tscn carries: 7 MeshInstance3D primitives (delta body + body taper +
;     canopy + nose cone + vertical fin + 2 horizontal stabilizers), a BoxShape3D
;     CollisionShape3D sized 9 × 1.5 × 7 m covering the assembly, and 4 Marker3D
;     sockets (MuzzleSocket / ChaseCamSocket / CockpitCamSocket / EngineFXSocket).
;   - Sockets are now reachable via $Aircraft/<SocketName> from this scene's scripts.

[node name="Player" type="RigidBody3D" groups=["player"]]
script = ExtResource("1_player_ctrl")
gravity_scale = 0.0
lock_rotation = false
linear_damp = 0.0
angular_damp = 5.0

; Hand-modeled delta-wing PackedScene instance (T-G-15).
; Owns: 7 MeshInstance3D primitives + CollisionShape3D + 4 Marker3D sockets.
[node name="Aircraft" parent="." instance=ExtResource("4_aircraft")]

; FlightArcade — arcade flight model node. Reads input, computes forces.
; apply_forces() called from player_controller._integrate_forces().
[node name="FlightArcade" type="Node" parent="."]
script = ExtResource("2_flight")

; CameraController — manages Chase + Cockpit cameras, handles cycle_camera action.
[node name="CameraController" type="Node3D" parent="."]
script = ExtResource("3_cam_ctrl")

; Chase SpringArm3D — arms out 12m behind + 4m above; child of CameraController.
; SpringArm3D automatically sweeps to avoid geometry, retaining line-of-sight.
[node name="ChaseSpringArm" type="SpringArm3D" parent="CameraController"]
position = Vector3(0.0, 4.0, 0.0)
rotation_degrees = Vector3(-10.0, 180.0, 0.0)
spring_length = 12.0
collision_mask = 1

; Chase Camera3D — active by default (current = true set by camera_controller._ready).
[node name="ChaseCamera" type="Camera3D" parent="CameraController/ChaseSpringArm"]
current = true
fov = 70.0

; Cockpit Camera3D — positioned at $Aircraft/CockpitCamSocket (forward-looking, no smoothing).
[node name="CockpitCamera" type="Camera3D" parent="CameraController"]
position = Vector3(0.0, 0.6, -0.8)
current = false
fov = 80.0
