; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows this.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Aero Fighters v2 — Stylized Inhauma"
config/description="Stylized cel-shaded arcade flight game over Inhauma MG. Spawn airborne over a topology-faithful 20 km radius world built from OpenStreetMap building footprints and NASA SRTM 30 m heightmaps. Fly, strafe, and destroy three target types (factory, base, AA cluster) in repeating mission cycles with escalating difficulty. Godot 4 Forward+ renderer, GDScript-first."
config/version="0.1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

MissionManager="*res://autoload/MissionManager.gd"
GameConfig="*res://autoload/GameConfig.gd"
Telemetry="*res://autoload/Telemetry.gd"
ImportTerrain="*res://tools_godot/import_terrain.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=0
window/vsync/vsync_mode=1

[input]

